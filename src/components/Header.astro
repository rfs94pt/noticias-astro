---
import { SITE } from '../site.config';
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">
      <svg
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="logo-icon"
        aria-hidden="true"
      >
        <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.8" fill="none" />
        <line x1="7" y1="8" x2="17" y2="8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <line x1="7" y1="12" x2="14" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <line x1="7" y1="16" x2="11" y2="16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <circle cx="20" cy="5" r="4" fill="var(--color-accent)" stroke="var(--color-header)" stroke-width="2" />
      </svg>
      notícias<span>d'astro</span>
    </a>
  </div>
</header>
