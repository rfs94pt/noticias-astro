---
import { SITE, ADS } from '../../site.config';
---

{ADS.enabled && (
  <div class="ad-zone ad-banner">
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={SITE.adsensePublisherId}
      data-ad-slot={ADS.bannerDesktopId}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
  </div>
)}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    try {
      window['adsbygoogle'] = window['adsbygoogle'] || [];
      window['adsbygoogle'].push({});
    } catch (_) {}
  });
</script>
