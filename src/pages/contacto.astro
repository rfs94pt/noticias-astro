---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto">
  <div class="page-wrapper">
    <h1 class="section-title">Contacto</h1>
    <article class="article-content">
      <p>Tem uma sugestão, denúncia ou pergunta? Entre em contacto connosco.</p>
      <p>
        <strong>Email:</strong>{' '}
        <a href="mailto:contacto@noticiashoje.pt" style="color:var(--color-accent);">
          contacto@noticiashoje.pt
        </a>
      </p>
      <p>
        <strong>Redação:</strong>{' '}
        <a href="mailto:redacao@noticiashoje.pt" style="color:var(--color-accent);">
          redacao@noticiashoje.pt
        </a>
      </p>
    </article>
  </div>
</BaseLayout>
