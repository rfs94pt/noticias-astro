---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sobre">
  <div class="page-wrapper">
    <h1 class="section-title">Sobre</h1>
    <article class="article-content">
      <p>
        O <strong>Notícias Hoje</strong> é um portal de notícias independente, focado em
        trazer informação atualizada, relevante e imparcial sobre Portugal e o mundo.
      </p>
      <h2>A Nossa Missão</h2>
      <p>
        Informar com rigor, clareza e independência. Acreditamos que o jornalismo de
        qualidade é essencial para uma sociedade democrática.
      </p>
      <h2>Contacto</h2>
      <p>
        Se quiser entrar em contacto connosco, visite a nossa{' '}
        <a href="/contacto" style="color:var(--color-accent);">página de contacto</a>.
      </p>
    </article>
  </div>
</BaseLayout>
