---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NoticiaCard from '../components/NoticiaCard.astro';
import { ADS } from '../site.config';

const noticias = await getCollection('noticias');
const sorted = noticias
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const hero = sorted[0];
const rest = sorted.slice(1, 8);

function formatDate(d: Date): string {
  return d.toLocaleDateString('pt-PT', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<BaseLayout>
  {hero && (
    <div class="hero">
      <a href={`/noticias/${hero.slug}`} class="hero-card">
        <img src={hero.data.image ?? '/og-default.jpg'} alt={hero.data.title} />
        <div class="hero-card-content">
          <span class="category">{hero.data.category}</span>
          <h2>{hero.data.title}</h2>
          <p>{hero.data.description}</p>
        </div>
      </a>
    </div>
  )}

  <div class="page-wrapper">
    <h2 class="section-title">Últimas Notícias</h2>
    <div class="news-grid">
      {rest.map((n, i) => (
        <>
          <NoticiaCard
            title={n.data.title}
            description={n.data.description}
            slug={n.slug}
            category={n.data.category}
            date={n.data.date}
            image={n.data.image}
          />
          {ADS.enabled && (i + 1) % 3 === 0 && (
            <div class="ad-zone ad-between-cards">
              <ins
                class="adsbygoogle"
                style="display:block"
                data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
                data-ad-slot="1234567894"
                data-ad-format="auto"
                data-full-width-responsive="true"
              ></ins>
            </div>
          )}
        </>
      ))}
    </div>

    {sorted.length > 8 && (
      <div style="text-align:center; margin-top:2rem;">
        <a href="/noticias" style="color:var(--color-accent); font-weight:600;">
          Ver todas as notícias →
        </a>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    try {
      window['adsbygoogle'] = window['adsbygoogle'] || [];
      window['adsbygoogle'].push({});
    } catch (_) {}
  });
</script>
