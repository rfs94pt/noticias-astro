---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NoticiaCard from '../components/NoticiaCard.astro';
import AdSidebar from '../components/ads/AdSidebar.astro';
import { ADS, SITE } from '../site.config';

const noticias = await getCollection('noticias');
const sorted = noticias.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime() || b.slug.localeCompare(a.slug),
);

const hero = sorted[0];
const rest = sorted.slice(1);
---

<BaseLayout>
  {hero ? (
    <>
      <div class="hero">
        <a href={`/noticias/${hero.slug}`} class="hero-card">
          <img
            src={hero.data.image ?? '/og-default.jpg'}
            alt={hero.data.title}
          />
          <div class="hero-card-content">
            <span class="category">{hero.data.category}</span>
            <h2>{hero.data.title}</h2>
            <p>{hero.data.description}</p>
          </div>
        </a>
      </div>

      <div class="content-with-sidebar">
        <main>
          <h2 class="section-title">Últimas Notícias</h2>
          <div class="news-grid">
            {rest.map((n, i) => (
              <>
                <NoticiaCard
                  title={n.data.title}
                  description={n.data.description}
                  slug={n.slug}
                  category={n.data.category}
                  date={n.data.date}
                  image={n.data.image}
                />
                {ADS.enabled && (i + 1) % 3 === 0 && (
                  <div class="ad-zone ad-between-cards">
                    <ins
                      class="adsbygoogle"
                      style="display:block"
                      data-ad-client={SITE.adsensePublisherId}
                      data-ad-slot={ADS.inContentId}
                      data-ad-format="auto"
                      data-full-width-responsive="true"
                    ></ins>
                  </div>
                )}
              </>
            ))}
          </div>
        </main>
        <AdSidebar />
      </div>
    </>
  ) : (
    <div class="empty-state">
      <svg
        width="64"
        height="64"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <line x1="7" y1="8" x2="17" y2="8" />
        <line x1="7" y1="12" x2="17" y2="12" />
        <line x1="7" y1="16" x2="12" y2="16" />
      </svg>
      <h2>Em breve</h2>
      <p>As primeiras notícias estão a caminho. Fica atento.</p>
    </div>
  )}
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    try {
      window['adsbygoogle'] = window['adsbygoogle'] || [];
      window['adsbygoogle'].push({});
    } catch (_) {}
  });
</script>
