---
import { getCollection } from 'astro:content';
import { SITE } from '../../site.config';
import NoticiaLayout from '../../layouts/NoticiaLayout.astro';
import AdInContent from '../../components/ads/AdInContent.astro';

interface Props {
  slug: string;
}

export async function getStaticPaths() {
  const noticias = await getCollection('noticias');
  return noticias.map((n) => ({ params: { slug: n.slug } }));
}

const { slug } = Astro.params;
const noticia = (await getCollection('noticias')).find((n) => n.slug === slug);

if (!noticia) {
  return Astro.redirect('/404');
}

const { title, description, date, category, image, tags } = noticia.data;
const { Content } = await noticia.render();

const formattedDate = date.toLocaleDateString('pt-PT', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const canonicalURL = `${SITE.url}/noticias/${slug}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: title,
  description: description,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  image: image ?? `${SITE.url}/og-default.jpg`,
  url: canonicalURL,
  author: {
    '@type': 'Organization',
    name: SITE.title,
    url: SITE.url,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.title,
    url: SITE.url,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE.url}/og-default.jpg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
};
---

<NoticiaLayout
  title={title}
  description={description}
  image={image ?? `${SITE.url}/og-default.jpg`}
  {canonicalURL}
>
  <header class="article-header">
    <nav class="breadcrumb">
      <a href="/">Início</a>
      <span>/</span>
      <span>{title}</span>
    </nav>
    <span class="article-category">{category}</span>
    <h1>{title}</h1>
    <time class="article-date" datetime={date.toISOString()}>{formattedDate}</time>
    {image && (
      <img src={image} alt={title} class="article-image" decoding="async" />
    )}
  </header>

  <div class="article-content">
    <Content />
    <AdInContent />
  </div>

  {tags && tags.length > 0 && (
    <div class="article-tags">
      {tags.map((t: string) => <span class="article-tag">{t}</span>)}
    </div>
  )}

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
</NoticiaLayout>
