---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoticiaCard from '../../components/NoticiaCard.astro';
import { ADS } from '../../site.config';

const noticias = await getCollection('noticias');
const sorted = noticias.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const pageSize = 12;
const totalPages = Math.ceil(sorted.length / pageSize);
const currentPage = 1;
const paginated = sorted.slice(0, pageSize);
---

<BaseLayout title="Todas as Notícias">
  <div class="page-wrapper">
    <h1 class="section-title">Todas as Notícias</h1>
    <div class="news-grid">
      {paginated.map((n, i) => (
        <>
          <NoticiaCard
            title={n.data.title}
            description={n.data.description}
            slug={n.slug}
            category={n.data.category}
            date={n.data.date}
            image={n.data.image}
          />
          {ADS.enabled && (i + 1) % 3 === 0 && (
            <div class="ad-zone ad-between-cards">
              <ins
                class="adsbygoogle"
                style="display:block"
                data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
                data-ad-slot="1234567894"
                data-ad-format="auto"
                data-full-width-responsive="true"
              ></ins>
            </div>
          )}
        </>
      ))}
    </div>

    {totalPages > 1 && (
      <nav class="pagination" style="margin-top:2.5rem;">
        <span class="current">1</span>
        {Array.from({ length: totalPages }, (_, i) => i + 1)
          .slice(1)
          .map((n) => (
            <a href={`/noticias/pagina/${n}`}>{n}</a>
          ))}
      </nav>
    )}
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    try {
      window['adsbygoogle'] = window['adsbygoogle'] || [];
      window['adsbygoogle'].push({});
    } catch (_) {}
  });
</script>
